NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Optional notes for local setup:
# 1. Copy this file to .env.local
# 2. Replace the values with the Supabase project for the target store
# 3. Do not reuse another store's Supabase URL or anon key